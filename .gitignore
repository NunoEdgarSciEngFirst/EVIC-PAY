# Root-level gitignore
# Dependencies

# ==========================
# Dependencies
# ==========================
node_modules/

# ==========================
# Next.js
# ==========================
.next/
out/

# ==========================
# Build outputs
# ==========================
dist/
build/

# ==========================
# Logs
# ==========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================
# Environment variables
# ==========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================
# Coverage reports
# ==========================
coverage/

# ==========================
# TypeScript
# ==========================
*.tsbuildinfo

# ==========================
# IDE / Editors
# ==========================
.vscode/
.idea/
*.swp
*.swo

# ==========================
# Operating System files
# ==========================
.DS_Store
Thumbs.db
desktop.ini

# ==========================
# Docker
# ==========================
docker-data/

# ==========================
# Temporary files
# ==========================
tmp/
temp/

# ==========================
# Package manager locks
# ==========================
# Keep ONE of these committed,
# depending on the package manager used.

# package-lock.json
# yarn.lock
# pnpm-lock.yaml
node_modules/
.pnp
.pnp.js

